<!DOCTYPE html>
<html>
<head>

<title>Login - Surabaya Marathon</title>

<style>

body{
font-family: Arial;
background:#f2f2f2;
display:flex;
justify-content:center;
align-items:center;
height:100vh;
margin:0;
}

.login-box{
background:white;
padding:40px;
width:350px;
border-radius:8px;
box-shadow:0 5px 20px rgba(0,0,0,0.1);
text-align:center;
}

.logo{
font-size:22px;
font-weight:bold;
color:#ff5a00;
margin-bottom:10px;
}

input{
width:100%;
padding:12px;
margin:10px 0;
border:1px solid #ddd;
border-radius:5px;
}

button{
width:100%;
padding:12px;
background:#ff5a00;
color:white;
border:none;
border-radius:5px;
font-size:16px;
cursor:pointer;
}

button:hover{
background:#e64a00;
}

a{
text-decoration:none;
color:#ff5a00;
}

</style>

</head>

<body>

<div class="login-box">

<div class="logo">SURABAYA MARATHON</div>

<h2>Log in</h2>

<form>

<input type="email" placeholder="Email address">

<input type="password" placeholder="Password">

<button type="submit">Log in</button>

</form>

<p>Belum punya akun? <a href="#">Daftar</a></p>

</div>

</body>

</html>
